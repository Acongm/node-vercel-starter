APP_NAME=node-vercel-starter
APP_VERSION=0.1.0
PORT=3000
RUNTIME_TARGET=node

# none | memory | file | mongo | postgres | redis | supabase
DATA_MODE=memory
DATA_FILE_PATH=.data/comments.json

# Comma-separated browser origins allowed to call the API.
# Wildcards match one subdomain segment, for example https://admin.acongm.com.
CORS_ORIGINS=https://acongm.com,https://*.acongm.com

# Required when DATA_MODE=supabase. Prefer a server-only service role key.
# If a service role key is unavailable, set SUPABASE_API_KEY to a publishable
# or anon key and set SUPABASE_REQUEST_SECRET to match private.api_secrets.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_API_KEY=
SUPABASE_REQUEST_SECRET=
SUPABASE_COMMENTS_TABLE=comments

# memory | local | vercel-blob | s3
FILE_MODE=memory
UPLOAD_DIR=uploads

# none | jwt | external
AUTH_MODE=none
AUTH_JWT_SECRET=change-me

# mock | openai | custom
AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini

# Format: provider=https://api.example.com,other=https://other.example.com
PROXY_ALLOWLIST=
