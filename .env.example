APP_NAME=node-vercel-starter
APP_VERSION=0.1.0
PORT=3000
RUNTIME_TARGET=node

# none | memory | file | mongo | postgres | redis
DATA_MODE=memory
DATA_FILE_PATH=.data/comments.json

# memory | local | vercel-blob | s3
FILE_MODE=memory
UPLOAD_DIR=uploads

# none | jwt | external
AUTH_MODE=none
AUTH_JWT_SECRET=change-me

# mock | openai | custom
AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini

# Format: provider=https://api.example.com,other=https://other.example.com
PROXY_ALLOWLIST=
